generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ProductModifiersList {
  A                 String
  B                 String
  products          products          @relation(fields: [A], references: [id], onDelete: Cascade)
  product_modifiers product_modifiers @relation(fields: [B], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_ProductModifiersList_AB_unique")
  @@index([B], map: "_ProductModifiersList_B_index")
  @@map("_ProductModifiersList")
}

model accounts {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  admins            admins  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model action_logs {
  id          String   @id
  adminId     String
  action      String
  entityType  String?
  entityId    String?
  oldValues   String?
  newValues   String?
  description String?
  details     String?
  createdAt   DateTime @default(now())
  admins      admins   @relation(fields: [adminId], references: [id])

  @@index([adminId])
}

model admins {
  id                                                       String               @id
  email                                                    String               @unique
  password                                                 String?
  name                                                     String
  role                                                     AdminRole            @default(SUPER_ADMIN)
  isActive                                                 Boolean              @default(true)
  createdBy                                                String?
  createdAt                                                DateTime             @default(now())
  updatedAt                                                DateTime
  trialEndsAt                                              DateTime?
  allowedTabs                                              String?
  googleId                                                 String?              @unique
  hasPassword                                              Boolean              @default(true)
  phone                                                    String?
  latitude                                                 Float?
  longitude                                                Float?
  transportType                                            String?
  vehicleNumber                                            String?
  maxLoad                                                  Int                  @default(0)
  isOnShift                                                Boolean              @default(false)
  shiftStartedAt                                           DateTime?
  shiftEndedAt                                             DateTime?
  lastSeenAt                                               DateTime?
  averageDeliveryMinutes                                   Float?
  companyBalance                                           Float                @default(0)
  salary                                                   Int                  @default(0)
  accounts                                                 accounts[]
  action_logs                                              action_logs[]
  admins                                                   admins?              @relation("adminsToadmins", fields: [createdBy], references: [id])
  other_admins                                             admins[]             @relation("adminsToadmins")
  conversations_conversations_participant1IdToadmins       conversations[]      @relation("conversations_participant1IdToadmins")
  conversations_conversations_participant2IdToadmins       conversations[]      @relation("conversations_participant2IdToadmins")
  customers_customers_createdByToadmins                    customers[]          @relation("customers_createdByToadmins")
  customers_customers_defaultCourierIdToadmins             customers[]          @relation("customers_defaultCourierIdToadmins")
  features                                                 features[]
  interface_configs                                        interface_configs?
  menu_sets                                                menu_sets[]
  messages                                                 messages[]
  order_audit_events                                       order_audit_events[]
  orders_orders_adminIdToadmins                            orders[]             @relation("orders_adminIdToadmins")
  orders_orders_courierIdToadmins                          orders[]             @relation("orders_courierIdToadmins")
  transactions_transactions_adminIdToadmins                transactions[]       @relation("transactions_adminIdToadmins")
  transactions_transactions_salaryRecipientAdminIdToadmins transactions[]       @relation("transactions_salaryRecipientAdminIdToadmins")
  websites                                                 websites?
}

model api_keys {
  id           String    @id
  ownerAdminId String
  label        String
  keyHash      String    @unique
  scopes       String    @default("read")
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  isRevoked    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([ownerAdminId])
}

model branches {
  id           String   @id
  ownerAdminId String
  name         String
  code         String?
  address      String?
  phone        String?
  latitude     Float?
  longitude    Float?
  timezone     String   @default("Asia/Tashkent")
  currency     String   @default("UZS")
  taxRate      Float    @default(0.12)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([ownerAdminId])
}

model cash_drawer_movements {
  id             String             @id
  shiftId        String
  type           CashDrawerMoveType
  amount         Float
  reason         String?
  performedBy    String?
  createdAt      DateTime           @default(now())
  cashier_shifts cashier_shifts     @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId, createdAt])
}

model cashier_shifts {
  id                    String                  @id
  cashierId             String
  registerId            String?
  openedAt              DateTime                @default(now())
  closedAt              DateTime?
  openingFloat          Float                   @default(0)
  closingCash           Float?
  expectedCash          Float?
  cashDelta             Float?
  totalSales            Float                   @default(0)
  totalTax              Float                   @default(0)
  totalDiscount         Float                   @default(0)
  totalTips             Float                   @default(0)
  ordersCount           Int                     @default(0)
  status                ShiftStatus             @default(OPEN)
  notes                 String?
  cash_drawer_movements cash_drawer_movements[]
  payments              payments[]

  @@index([cashierId, openedAt])
}

model conversations {
  id                                          String     @id
  participant1Id                              String
  participant2Id                              String
  lastMessage                                 String?
  lastMessageAt                               DateTime   @default(now())
  createdAt                                   DateTime   @default(now())
  updatedAt                                   DateTime
  admins_conversations_participant1IdToadmins admins     @relation("conversations_participant1IdToadmins", fields: [participant1Id], references: [id], onDelete: Cascade)
  admins_conversations_participant2IdToadmins admins     @relation("conversations_participant2IdToadmins", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages                                    messages[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
}

model customers {
  id                                        String           @id
  name                                      String
  nickName                                  String?
  phone                                     String
  address                                   String
  preferences                               String?
  orderPattern                              String?
  password                                  String?
  isActive                                  Boolean          @default(true)
  createdAt                                 DateTime         @default(now())
  updatedAt                                 DateTime
  latitude                                  Float?
  longitude                                 Float?
  deletedAt                                 DateTime?
  deletedBy                                 String?
  createdBy                                 String?
  defaultCourierId                          String?
  calories                                  Int              @default(2000)
  planType                                  PlanType         @default(CLASSIC)
  dailyPrice                                Int              @default(84000)
  notes                                     String?
  deliveryDays                              String?
  autoOrdersEnabled                         Boolean          @default(true)
  balance                                   Float            @default(0)
  assignedSetId                             String?
  email                                     String?
  birthday                                  DateTime?
  totalSpent                                Float            @default(0)
  totalOrders                               Int              @default(0)
  lastOrderAt                               DateTime?
  tags                                      String?
  menu_sets                                 menu_sets?       @relation(fields: [assignedSetId], references: [id])
  admins_customers_createdByToadmins        admins?          @relation("customers_createdByToadmins", fields: [createdBy], references: [id])
  admins_customers_defaultCourierIdToadmins admins?          @relation("customers_defaultCourierIdToadmins", fields: [defaultCourierId], references: [id])
  loyalty_members                           loyalty_members?
  orders                                    orders[]
  transactions                              transactions[]

  @@unique([phone, createdBy, deletedAt])
}

model daily_cooking_plans {
  id          String   @id
  date        DateTime @unique
  menuNumber  Int
  dishes      Json
  cookedStats Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model discounts {
  id           String       @id
  ownerAdminId String
  name         String
  code         String?
  type         DiscountType
  value        Float
  minSubtotal  Float?
  startsAt     DateTime?
  endsAt       DateTime?
  usageLimit   Int?
  usageCount   Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())

  @@unique([ownerAdminId, code])
  @@index([ownerAdminId])
}

model dishes {
  id              String   @id
  name            String
  description     String?
  mealType        String
  ingredients     Json
  calorieMappings Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  menus           menus[]  @relation("DishToMenu")
}

model features {
  id           String      @id
  ownerAdminId String
  name         String
  description  String
  type         FeatureType
  options      Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime
  admins       admins      @relation(fields: [ownerAdminId], references: [id], onDelete: Cascade)

  @@index([ownerAdminId])
}

model gift_card_redemptions {
  id          String     @id
  giftCardId  String
  orderId     String?
  amount      Float
  performedBy String?
  createdAt   DateTime   @default(now())
  gift_cards  gift_cards @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId, createdAt])
}

model gift_cards {
  id                    String                  @id
  ownerAdminId          String
  code                  String                  @unique
  initialValue          Float
  balance               Float
  currency              String                  @default("UZS")
  issuedToName          String?
  issuedToPhone         String?
  issuedAt              DateTime                @default(now())
  expiresAt             DateTime?
  isActive              Boolean                 @default(true)
  notes                 String?
  gift_card_redemptions gift_card_redemptions[]

  @@index([ownerAdminId])
}

model interface_configs {
  id       String @id
  adminId  String @unique
  theme    String @default("light")
  language String @default("ru")
  admins   admins @relation(fields: [adminId], references: [id])
}

model loyalty_members {
  id                  String                @id
  programId           String
  customerId          String                @unique
  points              Int                   @default(0)
  lifetimeSpent       Float                 @default(0)
  tier                String?
  joinedAt            DateTime              @default(now())
  customers           customers             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  loyalty_programs    loyalty_programs      @relation(fields: [programId], references: [id], onDelete: Cascade)
  loyalty_points_logs loyalty_points_logs[]

  @@index([programId])
}

model loyalty_points_logs {
  id              String          @id
  memberId        String
  delta           Int
  reason          String
  reference       String?
  createdAt       DateTime        @default(now())
  loyalty_members loyalty_members @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, createdAt])
}

model loyalty_programs {
  id                String            @id
  ownerAdminId      String            @unique
  name              String            @default("Loyalty Program")
  pointsPerCurrency Float             @default(1)
  currencyPerPoint  Float             @default(100)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  loyalty_members   loyalty_members[]
  loyalty_tiers     loyalty_tiers[]
}

model loyalty_tiers {
  id               String           @id
  programId        String
  name             String
  minPoints        Int              @default(0)
  multiplier       Float            @default(1.0)
  benefits         String?
  color            String?
  loyalty_programs loyalty_programs @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

model menu_sets {
  id            String      @id
  name          String
  description   String?
  menuNumber    Int         @default(0)
  calorieGroups Json
  isActive      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  adminId       String?
  customers     customers[]
  admins        admins?     @relation(fields: [adminId], references: [id])

  @@index([adminId])
}

model menus {
  id        String   @id
  number    Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime
  dishes    dishes[] @relation("DishToMenu")
}

model messages {
  id             String        @id
  conversationId String
  senderId       String
  content        String
  isRead         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  conversations  conversations @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  admins         admins        @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model notifications {
  id          String           @id
  recipientId String
  type        NotificationType
  title       String
  body        String?
  link        String?
  data        Json?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([recipientId, createdAt])
}

model order_audit_events {
  id             String            @id
  orderId        String
  eventType      OrderEventType
  actorAdminId   String?
  actorRole      String?
  actorName      String?
  previousStatus order_status_new?
  nextStatus     order_status_new?
  payload        Json?
  message        String?
  occurredAt     DateTime          @default(now())
  admins         admins?           @relation(fields: [actorAdminId], references: [id])
  orders         orders            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, occurredAt])
}

model order_items {
  id           String    @id
  orderId      String
  productId    String?
  variantId    String?
  name         String
  sku          String?
  quantity     Float     @default(1)
  unitPrice    Float
  discount     Float     @default(0)
  taxRate      Float     @default(0)
  total        Float
  modifiers    Json?
  notes        String?
  courseNumber Int?
  firedAt      DateTime?
  readyAt      DateTime?
  createdAt    DateTime  @default(now())
  orders       orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  products     products? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model orders {
  id                              String               @id
  orderNumber                     Int                  @unique
  status                          order_status_new     @default(NEW)
  customerId                      String
  deliveryDate                    DateTime?            @default(now())
  deliveryAddress                 String
  deliveryTime                    String?
  latitude                        Float?
  longitude                       Float?
  quantity                        Int                  @default(1)
  calories                        Int                  @default(1600)
  specialFeatures                 String?
  notes                           String?
  paymentStatus                   PaymentStatus        @default(UNPAID)
  paymentMethod                   PaymentMethod        @default(CASH)
  isPrepaid                       Boolean              @default(false)
  priority                        Int                  @default(3)
  sourceChannel                   String?              @default("ADMIN_PANEL")
  statusChangedAt                 DateTime             @default(now())
  assignedAt                      DateTime?
  pickedUpAt                      DateTime?
  pausedAt                        DateTime?
  resumedAt                       DateTime?
  deliveredAt                     DateTime?
  failedAt                        DateTime?
  canceledAt                      DateTime?
  confirmedAt                     DateTime?
  etaMinutes                      Int?
  routeDistanceKm                 Float?
  routeDurationMin                Int?
  sequenceInRoute                 Int?
  customerRating                  Int?
  customerFeedback                String?
  amountReceived                  Float?
  lastLatitude                    Float?
  lastLongitude                   Float?
  lastLocationAt                  DateTime?
  createdAt                       DateTime             @default(now())
  updatedAt                       DateTime
  orderType                       OrderType            @default(MORNING)
  fromAutoOrder                   Boolean              @default(false)
  deletedAt                       DateTime?
  adminId                         String?
  courierId                       String?
  subtotal                        Float                @default(0)
  taxTotal                        Float                @default(0)
  discountTotal                   Float                @default(0)
  tipTotal                        Float                @default(0)
  grandTotal                      Float                @default(0)
  tableId                         String?
  guestCount                      Int?
  serviceMode                     String?
  order_audit_events              order_audit_events[]
  order_items                     order_items[]
  admins_orders_adminIdToadmins   admins?              @relation("orders_adminIdToadmins", fields: [adminId], references: [id])
  admins_orders_courierIdToadmins admins?              @relation("orders_courierIdToadmins", fields: [courierId], references: [id])
  customers                       customers            @relation(fields: [customerId], references: [id])
  payments                        payments[]
  receipts                        receipts[]
}

model payments {
  id             String           @id
  orderId        String
  shiftId        String?
  method         PaymentMethod
  amount         Float
  tip            Float            @default(0)
  changeGiven    Float            @default(0)
  reference      String?
  refundedAmount Float            @default(0)
  status         PaymentTxnStatus @default(COMPLETED)
  processedAt    DateTime         @default(now())
  processedBy    String?
  orders         orders           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cashier_shifts cashier_shifts?  @relation(fields: [shiftId], references: [id])

  @@index([orderId])
  @@index([shiftId])
}

model printer_devices {
  id           String      @id
  ownerAdminId String
  name         String
  type         PrinterType @default(RECEIPT)
  connection   String      @default("network")
  ipAddress    String?
  port         Int?        @default(9100)
  bluetoothMac String?
  paperWidth   String      @default("80mm")
  isDefault    Boolean     @default(false)
  isActive     Boolean     @default(true)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime

  @@index([ownerAdminId])
}

model product_categories {
  id                       String               @id
  ownerAdminId             String
  name                     String
  color                    String?
  icon                     String?
  parentId                 String?
  sortOrder                Int                  @default(0)
  isActive                 Boolean              @default(true)
  kitchenStation           String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime
  product_categories       product_categories?  @relation("product_categoriesToproduct_categories", fields: [parentId], references: [id])
  other_product_categories product_categories[] @relation("product_categoriesToproduct_categories")
  products                 products[]

  @@index([ownerAdminId])
}

model product_modifiers {
  id                   String                 @id
  ownerAdminId         String
  name                 String
  priceDelta           Float                  @default(0)
  groupName            String?
  isRequired           Boolean                @default(false)
  maxSelect            Int                    @default(1)
  createdAt            DateTime               @default(now())
  ProductModifiersList ProductModifiersList[]

  @@index([ownerAdminId])
}

model product_variants {
  id          String   @id
  productId   String
  name        String
  sku         String?
  barcode     String?
  priceDelta  Float    @default(0)
  stockOnHand Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  products    products @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model products {
  id                   String                 @id
  ownerAdminId         String
  sku                  String?
  barcode              String?
  name                 String
  description          String?
  categoryId           String?
  imageUrl             String?
  costPrice            Float?
  sellPrice            Float                  @default(0)
  taxRate              Float                  @default(0)
  trackStock           Boolean                @default(true)
  stockOnHand          Float                  @default(0)
  reorderLevel         Float?
  unit                 String                 @default("pcs")
  isActive             Boolean                @default(true)
  isFavorite           Boolean                @default(false)
  color                String?
  kitchenStation       String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  ProductModifiersList ProductModifiersList[]
  order_items          order_items[]
  product_variants     product_variants[]
  product_categories   product_categories?    @relation(fields: [categoryId], references: [id])
  stock_movements      stock_movements[]

  @@unique([ownerAdminId, barcode])
  @@unique([ownerAdminId, sku])
  @@index([categoryId])
  @@index([ownerAdminId])
}

model purchase_order_items {
  id              String          @id
  purchaseOrderId String
  productId       String?
  warehouseItemId String?
  name            String
  quantity        Float
  unitCost        Float
  total           Float
  purchase_orders purchase_orders @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model purchase_orders {
  id                   String                 @id
  ownerAdminId         String
  supplierId           String
  reference            String?
  status               PurchaseOrderStatus    @default(DRAFT)
  totalCost            Float                  @default(0)
  receivedAt           DateTime?
  notes                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  purchase_order_items purchase_order_items[]
  suppliers            suppliers              @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([ownerAdminId])
  @@index([supplierId])
}

model receipts {
  id            String      @id
  orderId       String
  receiptNumber String      @unique
  type          ReceiptType @default(SALE)
  format        String      @default("80mm")
  payload       Json
  printedAt     DateTime?
  emailedTo     String?
  smsTo         String?
  createdAt     DateTime    @default(now())
  orders        orders      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model reservations {
  id                String             @id
  ownerAdminId      String
  tableId           String?
  customerName      String
  customerPhone     String?
  partySize         Int                @default(2)
  startsAt          DateTime
  durationMin       Int                @default(90)
  status            ReservationStatus  @default(BOOKED)
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime
  restaurant_tables restaurant_tables? @relation(fields: [tableId], references: [id])

  @@index([ownerAdminId, startsAt])
}

model restaurant_tables {
  id             String          @id
  ownerAdminId   String
  name           String
  sectionId      String?
  capacity       Int             @default(4)
  shape          String          @default("rect")
  positionX      Float           @default(0)
  positionY      Float           @default(0)
  width          Float           @default(80)
  height         Float           @default(80)
  status         TableStatus     @default(AVAILABLE)
  currentOrderId String?
  qrToken        String?         @unique
  qrEnabled      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  reservations   reservations[]
  table_sections table_sections? @relation(fields: [sectionId], references: [id])

  @@index([ownerAdminId])
  @@index([sectionId])
}

model shift_checklist_instances {
  id                        String                      @id
  templateId                String
  shiftId                   String?
  performedBy               String
  startedAt                 DateTime                    @default(now())
  completedAt               DateTime?
  createdAt                 DateTime                    @default(now())
  shift_checklist_templates shift_checklist_templates   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  shift_checklist_responses shift_checklist_responses[]

  @@index([performedBy, startedAt])
  @@index([shiftId])
}

model shift_checklist_items {
  id                        String                      @id
  templateId                String
  label                     String
  required                  Boolean                     @default(true)
  sortOrder                 Int                         @default(0)
  createdAt                 DateTime                    @default(now())
  shift_checklist_templates shift_checklist_templates   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  shift_checklist_responses shift_checklist_responses[]

  @@index([templateId, sortOrder])
}

model shift_checklist_responses {
  id                        String                    @id
  instanceId                String
  itemId                    String
  checked                   Boolean                   @default(false)
  note                      String?
  checkedAt                 DateTime?
  createdAt                 DateTime                  @default(now())
  shift_checklist_instances shift_checklist_instances @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  shift_checklist_items     shift_checklist_items     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([instanceId, itemId])
}

model shift_checklist_templates {
  id                        String                      @id
  ownerAdminId              String
  name                      String
  phase                     ShiftChecklistPhase         @default(OPENING)
  isActive                  Boolean                     @default(true)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime
  shift_checklist_instances shift_checklist_instances[]
  shift_checklist_items     shift_checklist_items[]

  @@index([ownerAdminId, phase])
}

model stock_movements {
  id          String            @id
  productId   String
  type        StockMovementType
  quantity    Float
  reason      String?
  reference   String?
  costPrice   Float?
  performedBy String?
  createdAt   DateTime          @default(now())
  products    products          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([productId])
}

model suppliers {
  id              String            @id
  ownerAdminId    String
  name            String
  contactName     String?
  phone           String?
  email           String?
  address         String?
  notes           String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  purchase_orders purchase_orders[]

  @@index([ownerAdminId])
}

model table_sections {
  id                String              @id
  ownerAdminId      String
  name              String
  color             String?
  sortOrder         Int                 @default(0)
  createdAt         DateTime            @default(now())
  restaurant_tables restaurant_tables[]

  @@index([ownerAdminId])
}

model tax_rates {
  id           String   @id
  ownerAdminId String
  name         String
  rate         Float
  isInclusive  Boolean  @default(false)
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([ownerAdminId])
}

model timeclock_entries {
  id           String    @id
  employeeId   String
  ownerAdminId String
  clockedInAt  DateTime
  clockedOutAt DateTime?
  breakMinutes Int       @default(0)
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([employeeId, clockedInAt])
  @@index([ownerAdminId])
}

model tip_pool_shares {
  id             String    @id
  poolId         String
  employeeId     String
  weight         Float     @default(1)
  computedAmount Float     @default(0)
  paidOut        Boolean   @default(false)
  paidOutAt      DateTime?
  createdAt      DateTime  @default(now())
  tip_pools      tip_pools @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([poolId])
}

model tip_pools {
  id              String            @id
  ownerAdminId    String
  fromDate        DateTime
  toDate          DateTime
  totalAmount     Float             @default(0)
  status          TipPoolStatus     @default(OPEN)
  createdBy       String?
  notes           String?
  createdAt       DateTime          @default(now())
  closedAt        DateTime?
  tip_pool_shares tip_pool_shares[]

  @@index([ownerAdminId, fromDate])
}

model transactions {
  id                                                 String          @id
  amount                                             Float
  type                                               TransactionType
  description                                        String?
  category                                           String?
  createdAt                                          DateTime        @default(now())
  adminId                                            String?
  salaryRecipientAdminId                             String?
  customerId                                         String?
  admins_transactions_adminIdToadmins                admins?         @relation("transactions_adminIdToadmins", fields: [adminId], references: [id])
  customers                                          customers?      @relation(fields: [customerId], references: [id])
  admins_transactions_salaryRecipientAdminIdToadmins admins?         @relation("transactions_salaryRecipientAdminIdToadmins", fields: [salaryRecipientAdminId], references: [id])

  @@index([adminId])
  @@index([customerId])
  @@index([salaryRecipientAdminId])
}

model warehouse_items {
  id           String   @id
  name         String   @unique
  amount       Float    @default(0)
  unit         String   @default("gr")
  kcalPerGram  Float?   @default(0)
  pricePerUnit Float?
  priceUnit    String   @default("kg")
  updatedAt    DateTime
}

model websites {
  id          String   @id
  adminId     String   @unique
  subdomain   String   @unique
  theme       String
  content     String
  chatEnabled Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  admins      admins   @relation(fields: [adminId], references: [id])
}


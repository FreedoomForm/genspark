generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Answer {
  id         String   @id @default(cuid())
  attemptId  String
  questionId Int
  selected   Int
  isCorrect  Boolean
  answeredAt DateTime @default(now())
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model Attempt {
  id             String    @id @default(cuid())
  userId         String    @unique
  questionIds    String
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  correctCount   Int       @default(0)
  incorrectCount Int       @default(0)
  totalCount     Int       @default(20)
  ipAddress      String?
  optionsShuffle String?
  answers        Answer[]
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ipAddress, startedAt])
}

model Lesson {
  id              String           @id @default(cuid())
  order           Int              @default(0)
  category        String
  screenshot      String?
  videoUrl        String?
  ruName          String
  uzName          String
  ruDescription   String?
  uzDescription   String?
  ruFunctionality String?
  uzFunctionality String?
  ruSteps         String?
  uzSteps         String?
  ruTips          String?
  uzTips          String?
  ruUseCase       String?
  uzUseCase       String?
  uiLocation      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  progress        LessonProgress[]

  @@index([category])
  @@index([order])
  @@map("lesson")
}

model LessonProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  viewedAt  DateTime @default(now())
  completed Boolean  @default(false)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
  @@index([userId])
}

model Question {
  id         Int      @id
  category   String
  screenshot String?
  ruQuestion String
  ruOptions  String[]
  uzQuestion String
  uzOptions  String[]
  correct    Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String
  password       String
  role           Role             @default(USER)
  createdAt      DateTime         @default(now())
  attempt        Attempt?
  lessonProgress LessonProgress[]
}

enum Role {
  USER
  ADMIN
}

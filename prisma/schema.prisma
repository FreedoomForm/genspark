generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String
  password       String
  role           Role             @default(USER)
  createdAt      DateTime         @default(now())
  attempt        Attempt?
  lessonProgress LessonProgress[]
}

enum Role {
  USER
  ADMIN
}

// One attempt per user (single-attempt rule). Created when the user starts
// the test. We persist the snapshot of the 20 randomly chosen question IDs
// so that refreshing the page does not reshuffle the test.
model Attempt {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionIds    String    // JSON array of 20 selected question IDs (as strings)
  optionsShuffle String?   // JSON object mapping questionId -> shuffled indices order
  ipAddress      String?   // IP address of the user who took the test
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  correctCount   Int       @default(0)
  incorrectCount Int       @default(0)
  totalCount     Int       @default(20)
  answers        Answer[]

  @@index([ipAddress, startedAt])
}

model Answer {
  id          String   @id @default(cuid())
  attemptId   String
  attempt     Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId  Int
  selected    Int      // index of the chosen option
  isCorrect   Boolean
  answeredAt  DateTime @default(now())

  @@unique([attemptId, questionId])
}

model Question {
  id          Int      @id
  category    String
  screenshot  String?
  ruQuestion  String
  ruOptions   String[] // Array of answer options in Russian
  uzQuestion  String
  uzOptions   String[] // Array of answer options in Uzbek
  correct     Int      // Index of correct answer
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lesson {
  id              String          @id @default(cuid())
  order           Int             @default(0) // Position in the list (for drag-and-drop)
  category        String          // warehouse, reference, finance, reports, settings, cabinet
  screenshot      String?         // Path to screenshot
  videoUrl        String?         // YouTube video URL for the lesson
  ruName          String          // Lesson name in Russian
  uzName          String          // Lesson name in Uzbek
  ruDescription   String?         // Description in Russian
  uzDescription   String?         // Description in Uzbek
  ruFunctionality String?         // What this button/feature does (Russian)
  uzFunctionality String?         // What this button/feature does (Uzbek)
  ruSteps         String?         // Step-by-step instructions (Russian)
  uzSteps         String?         // Step-by-step instructions (Uzbek)
  ruTips          String?         // Tips and best practices (Russian)
  uzTips          String?         // Tips and best practices (Uzbek)
  ruUseCase       String?         // When to use this feature (Russian)
  uzUseCase       String?         // When to use this feature (Uzbek)
  uiLocation      String?         // Where in the UI this is located
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  progress        LessonProgress[]

  @@index([category])
  @@index([order])
}

// Track which lessons each user has viewed/completed
model LessonProgress {
  id         String   @id @default(cuid())
  userId     String
  lessonId   String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  viewedAt   DateTime @default(now())
  completed  Boolean  @default(false)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

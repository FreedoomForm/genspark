generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Answer {
  id         String   @id
  attemptId  String
  questionId Int
  selected   Int
  isCorrect  Boolean
  answeredAt DateTime @default(now())
  Attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model Attempt {
  id             String    @id
  userId         String    @unique
  questionIds    String
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  correctCount   Int       @default(0)
  incorrectCount Int       @default(0)
  totalCount     Int       @default(20)
  ipAddress      String?
  optionsShuffle String?
  Answer         Answer[]
  User           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ipAddress, startedAt])
}

model LessonProgress {
  id        String   @id
  userId    String
  lessonId  String
  viewedAt  DateTime @default(now())
  completed Boolean  @default(false)
  lesson    lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
  @@index([userId])
}

model Question {
  id         Int      @id
  category   String
  screenshot String?
  ruQuestion String
  ruOptions  String[]
  uzQuestion String
  uzOptions  String[]
  correct    Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime
}

model User {
  id             String           @id
  email          String           @unique
  name           String
  password       String
  role           Role             @default(USER)
  createdAt      DateTime         @default(now())
  Attempt        Attempt?
  LessonProgress LessonProgress[]
}

model lesson {
  id              String           @id
  order           Int              @default(0)
  category        String
  screenshot      String?
  videoUrl        String?
  ruName          String
  uzName          String
  ruDescription   String?
  uzDescription   String?
  uiLocation      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  ruFunctionality String?
  ruSteps         String?
  ruTips          String?
  ruUseCase       String?
  uzFunctionality String?
  uzSteps         String?
  uzTips          String?
  uzUseCase       String?
  LessonProgress  LessonProgress[]

  @@index([category])
  @@index([order])
}

enum Role {
  USER
  ADMIN
}

# Neon Postgres connection string (use the pooled connection for serverless)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Optional non-pooled connection for migrations
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Random long string used to sign session JWTs
AUTH_SECRET="change-me-to-a-very-long-random-string"

# Hardcoded admin credentials (admin login in the UI)
ADMIN_EMAIL="admin@lumequiz.local"
ADMIN_PASSWORD="admin123"
